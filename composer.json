{
	"name": "trispania/welow-rrhh",
	"description": "Welow RRHH — plugin WordPress white-label para procesos de RRHH en PYMES (núcleo modular + Fichajes + Vacaciones).",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"keywords": ["wordpress", "plugin", "rrhh", "hr", "vacaciones", "fichajes", "time-tracking", "vacations"],
	"authors": [
		{
			"name": "Trispania",
			"homepage": "https://github.com/trispania-git"
		}
	],
	"require": {
		"php": "^8.1",
		"ext-json": "*",
		"ext-mbstring": "*",
		"ext-openssl": "*"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"squizlabs/php_codesniffer": "^3.10",
		"wp-coding-standards/wpcs": "^3.1",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"Welow\\RRHH\\": "src/",
			"Welow\\RRHH\\Modules\\TimeTracking\\": "modules/time-tracking/src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Welow\\RRHH\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"test": "phpunit"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
